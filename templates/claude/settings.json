{
  "permissions": {
    "allow": [
      "Bash(node scripts/agent/check.mjs*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/agent/check.mjs --only instructions"
          }
        ]
      }
    ]
  }
}
