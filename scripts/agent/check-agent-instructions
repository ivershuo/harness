#!/usr/bin/env sh
set -eu

fail() {
  printf '%s\n' "check-agent-instructions: $*" >&2
  exit 1
}

[ -f AGENTS.md ] || fail "missing AGENTS.md"
[ -f CLAUDE.md ] || fail "missing CLAUDE.md"
[ -f BRAIN.md ] || fail "missing BRAIN.md"
[ -d .agents/skills ] || fail "missing .agents/skills"
[ -d .claude/skills ] || fail "missing .claude/skills"
[ -d .claude/agents ] || fail "missing .claude/agents"

agent_lines=$(wc -l < AGENTS.md | tr -d ' ')
[ "$agent_lines" -le 150 ] || fail "AGENTS.md should stay under 150 lines; found $agent_lines"

grep -q '@AGENTS.md' CLAUDE.md || fail "CLAUDE.md must import AGENTS.md"
grep -q 'docs/SECURITY.md' AGENTS.md || fail "AGENTS.md must link security docs"
grep -q 'docs/PERFORMANCE.md' AGENTS.md || fail "AGENTS.md must link performance docs"
grep -q 'BRAIN.md' AGENTS.md || fail "AGENTS.md must link project brain"

for skill in feature-plan bug-repro pr-review security-review doc-gardener brain-ingest; do
  [ -f ".agents/skills/$skill/SKILL.md" ] || fail "missing Codex skill: $skill"
  [ -f ".claude/skills/$skill/SKILL.md" ] || fail "missing Claude skill: $skill"
done

for agent in planner implementer evaluator code-reviewer security-reviewer test-runner debugger; do
  [ -f ".claude/agents/$agent.md" ] || fail "missing Claude subagent: $agent"
done

printf '%s\n' "check-agent-instructions: ok"
